# Database
DATABASE_URL="postgresql://user:password@localhost:5432/in_your_corner?schema=public"

# Twilio (get from https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
# Optional: use for webhook signature validation
TWILIO_WEBHOOK_AUTH_TOKEN=

# Cron (bearer token or query param for /api/cron/send-daily-support). Use a long random string.
CRON_SECRET=

# AI (OpenAI) — optional; when set, daily message can be AI-generated
OPENAI_API_KEY=
# Set to "true" to use AI-generated daily message + resources (falls back to templates if unset or generation fails)
USE_AI_DAILY_MESSAGE=true

# App (optional: default is Calgary — America/Edmonton)
APP_TIMEZONE=America/Edmonton
NEXT_PUBLIC_APP_NAME="In Your Corner"
